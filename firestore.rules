rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user owns their own data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Households: any authenticated user can read/create.
    // Update allowed if you're already a member OR if you're adding yourself
    // (join flow) and you're not changing the invite code.
    match /households/{householdId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.memberUids ||
        (
          request.auth.uid in request.resource.data.memberUids &&
          request.resource.data.inviteCode == resource.data.inviteCode
        )
      );
    }

    // Household shared data sub-documents
    match /households/{householdId}/data/{doc} {
      allow read, write: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberUids;
    }
  }
}
